# syntax=docker/dockerfile:1
# Указывает Docker'у версию синтаксиса для корректной обработки файла.

# ------------------------------
# Стадия 1: сборка зависимостей
# ------------------------------
FROM python:3.12-slim AS builder
# Используется лёгкий образ Python. Стадия называется builder.

WORKDIR /build
# Рабочая папка для сборки.

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*
# Устанавливается компилятор (нужен для gevent), кэш apt удаляется для уменьшения размера.

COPY requirements.txt .
# Копируется файл с зависимостями.

RUN pip install --no-cache-dir --user -r requirements.txt
# Устанавливаются Python-пакеты в домашнюю папку пользователя. Кэш pip не сохраняется.

# ------------------------------
# Стадия 2: финальный образ
# ------------------------------
FROM python:3.12-slim
# Снова используется чистый лёгкий образ Python.

RUN useradd -m appuser
# Создаётся непривилегированный пользователь для запуска приложения.

WORKDIR /app
# Рабочая папка для приложения.

COPY --from=builder --chown=appuser:appuser /root/.local /home/appuser/.local
# Из стадии builder копируются установленные пакеты. Права передаются пользователю appuser.

ENV PATH="/home/appuser/.local/bin:$PATH"
# Путь к бинарникам пакетов добавляется в PATH, чтобы команды были доступны без полного пути.

COPY --chown=appuser:appuser app.py .
COPY --chown=appuser:appuser templates ./templates
COPY --chown=appuser:appuser static ./static
# Копируется код приложения. Владелец файлов — appuser.

USER appuser
# Дальнейшие команды выполняются от имени пользователя appuser.

EXPOSE 5000
# Объявляется, что приложение использует порт 5000.

CMD ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "4", "--worker-class", "gevent", "app:app"]
# Запускается gunicorn с 4 воркерами и асинхронными gevent-воркерами. Приложение берётся из app:app.

# КАК ЭТО РАБОТАЕТ:
# -----------------
# 1. Docker последовательно выполняет инструкции, создавая образ.
# 2. На стадии builder устанавливаются все зависимости, включая компиляторы.
# 3. На финальной стадии создаётся чистый образ с пользователем appuser.
# 4. Из стадии builder копируются только готовые пакеты, без мусора от компиляции.
# 5. Код приложения копируется с правами appuser.
# 6. Приложение запускается от непривилегированного пользователя.
# 7. Gunicorn с gevent-воркерами обрабатывает запросы асинхронно.
# 8. Multi-stage сборка делает итоговый образ минимальным по размеру.